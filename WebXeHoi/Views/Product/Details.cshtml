@model WebXeHoi.Models.Product

@{
    ViewData["Title"] = "Details";
}

<h1>Chi Tiết Sản Phẩm</h1>
<h3>@Model.Name</h3>

<hr />

<div class="row">
    <div class="col-sm-4">
        @if (Model.ImageUrl != null)
        {
            <img src="@Model.ImageUrl" width="150pt" />
        }
    </div>

    <div class="col-sm-8">
        <table class="table table-borderless">
            <tbody>
                <tr>
                    <td style="width: 20%; font-weight: bold;">Giá:</td>
                    <td>@Html.DisplayFor(model => model.Price)</td>
                </tr>
                <tr>
                    <td style="font-weight: bold;">Mô tả:</td>
                    <td>@Html.DisplayFor(model => model.Description)</td>
                </tr>
                <tr>
                    <td style="font-weight: bold;">Loại:</td>
                    <td>@Html.DisplayFor(model => model.Category.Name)</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<br />

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Chinh Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại Danh sách</a>
</div>